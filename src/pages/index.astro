---
import LayerBuilder from "../components/LayerBuilder.jsx";
import { getNews } from "../lib/news";

// Session lookup — commented out until accounts are enabled:
// import { parseCookieToken, getSession } from "../lib/auth";

const env = Astro.locals.runtime?.env;
const kv = env?.CACHE ?? null;
const ttl = Number(env?.NEWS_CACHE_TTL_SECONDS ?? 300);

const initialNewsItems = await getNews(kv, ttl);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trance Composer</title>
    <meta
      name="description"
      content="A layer-based trance composition system built with Astro, React, and Strudel."
    />
  </head>
  <body>
    <LayerBuilder client:load initialNewsItems={initialNewsItems} />
  </body>
</html>
